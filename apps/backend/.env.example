# =============================================
# AgroFlete Backend - Variables de Entorno
# =============================================
# Copiar este archivo como .env y completar los valores

# Servidor
PORT=8000
ENVIRONMENT=development

# =============================================
# Supabase
# =============================================
# Obtené esta URL en Supabase -> Settings -> Database -> Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres.xxx:password@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# Claves de la API de Supabase para Auth/Storage (Supabase -> Settings -> API)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_KEY=ey...

# =============================================
# Redis
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================
# Terceros
# =============================================
# Twilio (SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
